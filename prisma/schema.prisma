generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Counter {
  id  String @id
  seq Int    @default(0)
}

model ActionLog {
  id             String          @id @default(cuid())
  action         String
  apiRoute       String?
  status         ActionLogStatus @default(SUCCESS)
  message        String?
  performerId    String?
  performerName  String?
  performerEmail String?
  performerRole  UserRole?
  targetType     String?
  targetId       String?
  targetName     String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime        @default(now())

  performer User? @relation("ActionLogPerformer", fields: [performerId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([performerId])
  @@index([action])
  @@index([apiRoute])
  @@index([status, createdAt])
}

model User {
  id             String          @id @default(cuid())
  userId         String          @unique
  email          String          @unique
  gender         Gender?
  firstName      String
  educationLevel EducationLevel?
  middleName     String?
  title          String?
  lastName       String
  password       String?
  phoneNumber    String?
  address        String?
  dateOfBirth    DateTime?
  name           String
  emailVerified  Boolean         @default(false)
  passport       String?
  idCard         String?
  bio            String?
  expertise      String[]        @default([])
  programId      String?
  status         UserStatus      @default(UNAPPROVED)
  isFirstLogin   Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  image          String?
  role           UserRole        @default(MENTEE)

  actionLogs                ActionLog[]               @relation("ActionLogPerformer")
  accounts                  Account[]                 @relation("UserAccounts")
  sessions                  Session[]                 @relation("UserSessions")
  program                   Program?                  @relation("UserProgram", fields: [programId], references: [id], onDelete: SetNull)
  programEnrollments        MenteeProgramEnrollment[]
  eventScores               EventScore[]
  enrollmentHistoriesPerformed EnrollmentHistory[]     @relation("EnrollmentHistoryPerformedBy")
  createdPrograms           Program[]                 @relation("ProgramCreatedBy")
  updatedPrograms           Program[]                 @relation("ProgramUpdatedBy")
  createdEvents             Event[]                   @relation("EventCreatedBy")
  updatedEvents             Event[]                   @relation("EventUpdatedBy")
  programsAsMentor          Program[]                 @relation("ProgramMentors")
  mentorAssignmentsAsMentor MentorshipAssignment[]    @relation("MentorshipAssignmentMentor")
  mentorAssignmentsAsMentee MentorshipAssignment[]    @relation("MentorshipAssignmentMentee")

  @@index([programId])
  @@index([role, status])
  @@map("user")
}

model Program {
  id                  String    @id @default(cuid())
  name                String    @unique
  description         String?
  levelCount          Int       @default(4)
  currentLevel        Int       @default(1)
  isActive            Boolean   @default(false)
  price               Float     @default(0)
  cohort              String?
  coverImage          String?
  applicationOpensAt  DateTime?
  startsAt            DateTime?
  endsAt              DateTime?
  applicationClosesAt DateTime?
  programBenefits     String[]  @default([])
  requirements        String[]  @default([])
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  createdById         String?
  updatedById         String?

  createdBy     User?                     @relation("ProgramCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?                     @relation("ProgramUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  mentees       User[]                    @relation("UserProgram")
  mentors       User[]                    @relation("ProgramMentors")
  announcements Announcement[]
  events        Event[]
  enrollments   MenteeProgramEnrollment[]
  assignments   MentorshipAssignment[]
  histories     EnrollmentHistory[]

  @@index([isActive])
  @@index([currentLevel])
  @@index([cohort])
  @@index([applicationOpensAt])
  @@index([applicationClosesAt])
  @@index([updatedById])
}

model Announcement {
  id        String   @id @default(cuid())
  programId String
  title     String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
  @@index([createdAt])
}

model Event {
  id          String   @id @default(cuid())
  generatedId String   @unique
  programId   String
  createdById String?
  updatedById String?
  title       String
  description String?
  note        String?
  venue       String   @default("")
  eventDate   DateTime
  eventTime   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program     Program    @relation(fields: [programId], references: [id], onDelete: Cascade)
  createdBy   User?      @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?      @relation("EventUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  eventScores EventScore[]

  @@index([programId])
  @@index([createdById])
  @@index([updatedById])
  @@index([isActive])
  @@index([eventDate])
}

model EventScore {
  id       String   @id @default(cuid())
  eventId  String
  userId   String
  score    Float    @default(0)
  remark   String?
  isLocked Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model MenteeProgramEnrollment {
  id           String                  @id @default(cuid())
  userId       String
  programId    String
  status       ProgramEnrollmentStatus @default(ACTIVE)
  totalScore   Float                   @default(0)
  averageScore Float                   @default(0)
  percentage   Float                   @default(0)
  position     Int?
  enrolledAt   DateTime                @default(now())
  completedAt  DateTime?
  droppedAt    DateTime?
  note         String?
  metadata     Json?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  program    Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  histories  EnrollmentHistory[]

  @@unique([userId, programId])
  @@index([userId])
  @@index([programId])
  @@index([status])
}

model EnrollmentHistory {
  id           String   @id @default(cuid())
  enrollmentId String
  programId    String
  fromLevel    Int
  toLevel      Int
  totalScore   Float?
  averageScore Float?
  percentage   Float?
  note         String?
  performedById String?
  movedAt      DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enrollment MenteeProgramEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  program    Program                @relation(fields: [programId], references: [id], onDelete: Cascade)
  performedBy User?                 @relation("EnrollmentHistoryPerformedBy", fields: [performedById], references: [id], onDelete: SetNull)

  @@index([enrollmentId, movedAt])
  @@index([programId, movedAt])
  @@index([performedById])
}

model MentorshipAssignment {
  id         String           @id @default(cuid())
  mentorId   String
  menteeId   String
  programId  String?
  isPrimary  Boolean          @default(true)
  status     AssignmentStatus @default(ACTIVE)
  assignedAt DateTime         @default(now())
  endedAt    DateTime?
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  mentor  User     @relation("MentorshipAssignmentMentor", fields: [mentorId], references: [id], onDelete: Cascade)
  mentee  User     @relation("MentorshipAssignmentMentee", fields: [menteeId], references: [id], onDelete: Cascade)
  program Program? @relation(fields: [programId], references: [id], onDelete: SetNull)

  @@unique([mentorId, menteeId, programId])
  @@index([mentorId])
  @@index([menteeId])
  @@index([programId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("UserSessions", fields: [userId], references: [id])

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation("UserAccounts", fields: [userId], references: [id])

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum Gender {
  MALE
  FEMALE
}

enum ActionLogStatus {
  SUCCESS
  FAILED
  INFO
}

enum UserRole {
  MENTOR
  MENTEE
  ADMIN
  SUPER_ADMIN
  TECH_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  UNAPPROVED
  SUSPENDED
  RESIGNED
  SACKED
}

enum EducationLevel {
  PRIMARY_1
  PRIMARY_2
  PRIMARY_3
  PRIMARY_4
  PRIMARY_5
  PRIMARY_6
  JS_1
  JS_2
  JS_3
  SS_1
  SS_2
  SS_3
  YEAR_1
  YEAR_2
  YEAR_3
  YEAR_4
  YEAR_5
  YEAR_6
  YEAR_7
}

enum ProgramEnrollmentStatus {
  ACTIVE
  COMPLETED
  PAUSED
  DROPPED
}

enum AssignmentStatus {
  ACTIVE
  INACTIVE
  COMPLETED
}


